; PART 1: THE KNOWLEDGE BASE (LOGIC & ONTOLOGY)

; A. Ontology of Contradictions 

(contradicts isFixed isMobile)
(contradicts isSolid isLiquid)
(contradicts isDead isAlive)

; Disjoint Types (An object cannot be both)
(disjoint-types Land Water)
(disjoint-types Natural Artifact)

; B. Symmetry Rules
; If A contradicts B, then B contradicts A.
(= (are-contradictory $a $b) (match &self (contradicts $a $b) True))
(= (are-contradictory $a $b) (match &self (contradicts $b $a) True))

(= (are-disjoint $a $b) (match &self (disjoint-types $a $b) True))
(= (are-disjoint $a $b) (match &self (disjoint-types $b $a) True))

; PART 2: ROBUST LIST PARSING HELPER

; Function to find the block starting with 'axioms' inside the spec list
(= (find-block $target_tag ()) Empty)
(= (find-block $target_tag (($tag $data) $tail))
   (if (== $tag $target_tag)
       ($tag $data)  
       (find-block $target_tag $tail)
   ))

; Recursion step for non-nested heads
(= (find-block $target_tag ($head $tail)) (find-block $target_tag $tail))

; Function to check membership in a list
(= (is-member $x ($x $rest)) True)
(= (is-member $x ($y $rest)) (is-member $x $rest))

; PART 3: VALIDATOR (JUDGE)

(= (check-consistency $concept_name)
   (let $conflict
        (collapse
            (match &self
                ; 1. Find the Concept in the AtomSpace
                (Concept $concept_name (spec $spec_list))
                
                ; 2. Extract the Axioms block
                (let (axioms $ax_list) (find-block axioms $spec_list)
                    
                    ; 3. Check for contradictions inside that list
                    (union
                        (match &self
                            (,
                               (is-member ($p1 $x) $ax_list)
                               (is-member ($p2 $x) $ax_list)
                               (True (are-contradictory $p1 $p2))
                            )
                            (Error (Contradiction $x $p1 $p2))
                        )
                    )
                )
            )
        )
        ; Verdict: If $conflict is empty, return True.
        (if (== $conflict ()) 
            (True) 
            $conflict
        )
   )
)

; PART 4: THE TEST PIPELINE

!(print ">>> 1. LOADING BLEND FILE...")

; Import the file generated by Python
!(import! &self blend_output)

!(print ">>> 2. RUNNING LOGIC CONSISTENCY CHECK...")

; Run the Validator on 'BlendedConcept'
!(let $result (check-consistency BlendedConcept)
    (if (== $result (True))
        (print "PASSED: The blend is logically consistent!")
        (print (format-args "FAILED: Logic Error Found: {}" ($result)))
    )
)
