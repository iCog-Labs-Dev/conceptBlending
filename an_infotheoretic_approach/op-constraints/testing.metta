(=(is-abbreivation $term) 
    (let* (
        ($relation (collapse(match &self (target (IsA $term $fullformed) $abbriv) (car-atom $abbriv))))
        ($result (if (== (abbreviation) $relation) True False))
    )
    $result
    )
)

